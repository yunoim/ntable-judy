# Copy to .env.local and fill in values.

ANTHROPIC_API_KEY=sk-ant-api03-...

# Kakao OAuth — https://developers.kakao.com → 내 애플리케이션 → REST API 키
KAKAO_REST_API_KEY=
KAKAO_CLIENT_SECRET=
KAKAO_REDIRECT_URI=http://localhost:3000/api/auth/kakao/callback

# 앱 기본 URL (redirect base) — 운영은 https://judy.ntable.kr
APP_URL=http://localhost:3000

# 관리자 카카오 회원번호 (string) — 첫 로그인 후 DB에서 확인 후 입력
ADMIN_KAKAO_ID=

# Session token signing — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

DATABASE_URL="postgresql://postgres:PASSWORD@HOST:PORT/railway?schema=judy"

# Web Push (VAPID) — generate with: node -e "console.log(require('web-push').generateVAPIDKeys())"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Cron secret — /api/cron/* 호출 보호용 (GitHub Actions secret과 동일 값)
CRON_SECRET=

# Cloudflare R2 (Object Read & Write 권한 토큰)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=judy-photos
R2_PUBLIC_URL=https://pub-XXXXXXXX.r2.dev
