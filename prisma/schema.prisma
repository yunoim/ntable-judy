generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["judy"]
}

model User {
  id           String  @id @default(cuid())
  kakaoId      String  @unique
  nickname     String
  emoji        String?
  profileImage String?
  email        String?

  birthday  DateTime?
  birthTime String?

  role       String    @default("pending")
  partner    Boolean   @default(false)
  approvedAt DateTime?
  approvedBy String?
  rejectedAt DateTime?
  rejectedBy String?

  createdAt   DateTime  @default(now())
  lastLoginAt DateTime?

  sessions             Session[]
  reviews              Review[]
  datesCreated         Date[]             @relation("DateCreator")
  anniversariesCreated Anniversary[]      @relation("AnniversaryCreator")
  anniversariesAbout   Anniversary[]      @relation("AnniversarySubject")
  buckets              Bucket[]           @relation("BucketCreator")
  capsules             TimeCapsule[]      @relation("CapsuleCreator")
  comments             DateComment[]
  photos               DatePhoto[]        @relation("PhotoUploader")
  pushSubs             PushSubscription[]
  personalEvents       PersonalEvent[]

  @@schema("judy")
}

model Session {
  token     String   @id
  userId    String
  expiresAt DateTime
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@schema("judy")
}

model Date {
  id              String    @id @default(cuid())
  number          Int       @unique
  title           String
  subtitle        String?
  area            String
  scheduledAt     DateTime
  scheduledEndAt  DateTime? // 다일 데이트(여행 등) 종료일. null이면 당일.
  startTime       String?
  endTime         String?
  status          String    @default("planned")
  estimatedCost Int?
  summary       String?
  themeNote     String?
  weather       String?
  historyLabel  String?

  aiInput       String?
  aiResponseRaw String?

  createdById String
  createdBy   User   @relation("DateCreator", fields: [createdById], references: [id])

  stops    Stop[]
  reviews  Review[]
  tags     DateTag[]
  comments DateComment[]
  photos   DatePhoto[]
  buckets  Bucket[]      @relation("BucketDoneOn")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("judy")
}

model Stop {
  id             Int     @id @default(autoincrement())
  dateId         String
  stepOrder      Int
  time           String
  emoji          String?
  name           String
  address        String?
  type           String?
  description    String?
  mapQuery       String
  naverMapUrl    String?
  cost           Int     @default(0)
  reservationUrl String?
  reserved       Boolean @default(false)

  date Date @relation(fields: [dateId], references: [id], onDelete: Cascade)

  @@index([dateId])
  @@schema("judy")
}

model Review {
  id        Int      @id @default(autoincrement())
  dateId    String
  userId    String
  stars     Int
  oneLine   String?
  createdAt DateTime @default(now())

  date Date @relation(fields: [dateId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([dateId, userId])
  @@schema("judy")
}

model DateTag {
  dateId String
  tag    String

  date Date @relation(fields: [dateId], references: [id], onDelete: Cascade)

  @@id([dateId, tag])
  @@schema("judy")
}

model Anniversary {
  id          Int      @id @default(autoincrement())
  label       String
  date        DateTime
  emoji       String?
  recurring   Boolean  @default(true)
  createdById String
  createdBy   User     @relation("AnniversaryCreator", fields: [createdById], references: [id])

  userId  String?
  subject User?   @relation("AnniversarySubject", fields: [userId], references: [id], onDelete: Cascade)
  kind    String?

  createdAt DateTime @default(now())

  @@unique([userId, kind])
  @@index([date])
  @@schema("judy")
}

model Bucket {
  id          Int       @id @default(autoincrement())
  title       String
  emoji       String?
  description String?
  area        String?
  priority    Int       @default(0)
  done        Boolean   @default(false)
  doneAt      DateTime?

  doneDateId String?
  doneDate   Date?   @relation("BucketDoneOn", fields: [doneDateId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User   @relation("BucketCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([done, priority])
  @@schema("judy")
}

model TimeCapsule {
  id       Int       @id @default(autoincrement())
  title    String
  body     String
  openAt   DateTime
  opened   Boolean   @default(false)
  openedAt DateTime?

  createdById String
  createdBy   User   @relation("CapsuleCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  @@index([openAt])
  @@schema("judy")
}

model DateComment {
  id        Int      @id @default(autoincrement())
  dateId    String
  date      Date     @relation(fields: [dateId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@index([dateId, createdAt])
  @@schema("judy")
}

model DatePhoto {
  id           Int      @id @default(autoincrement())
  dateId       String
  date         Date     @relation(fields: [dateId], references: [id], onDelete: Cascade)
  url          String
  key          String?
  caption      String?
  width        Int?
  height       Int?
  uploadedById String
  uploadedBy   User     @relation("PhotoUploader", fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([dateId, createdAt])
  @@schema("judy")
}

model PersonalEvent {
  id        Int       @id @default(autoincrement())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  startsAt  DateTime
  endsAt    DateTime?
  allDay    Boolean   @default(false)
  category  String?
  emoji     String?
  note      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, startsAt])
  @@index([startsAt])
  @@schema("judy")
}

model PushSubscription {
  id         Int       @id @default(autoincrement())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint   String    @unique
  p256dh     String
  auth       String
  userAgent  String?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  @@index([userId])
  @@schema("judy")
}
