generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["judy"]
}

model User {
  id           String  @id @default(cuid())
  kakaoId      String  @unique
  nickname     String
  emoji        String?
  profileImage String?
  email        String?

  birthday  DateTime?
  birthTime String?

  role       String    @default("pending")
  partner    Boolean   @default(false)
  approvedAt DateTime?
  approvedBy String?
  rejectedAt DateTime?
  rejectedBy String?

  createdAt   DateTime  @default(now())
  lastLoginAt DateTime?

  sessions             Session[]
  reviews              Review[]
  datesCreated         Date[]             @relation("DateCreator")
  anniversariesCreated Anniversary[]      @relation("AnniversaryCreator")
  anniversariesAbout   Anniversary[]      @relation("AnniversarySubject")
  buckets              Bucket[]           @relation("BucketCreator")
  capsules             TimeCapsule[]      @relation("CapsuleCreator")
  comments             DateComment[]
  photos               DatePhoto[]        @relation("PhotoUploader")
  pushSubs             PushSubscription[]
  personalEvents       PersonalEvent[]
  chatMessages         ChatMessage[]
  chatRead             ChatRead?
  dailyEntries         DailyEntry[]

  @@schema("judy")
}

model Session {
  token     String   @id
  userId    String
  expiresAt DateTime
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@schema("judy")
}

model Date {
  id              String    @id @default(cuid())
  number          Int       @unique
  title           String
  subtitle        String?
  area            String
  scheduledAt     DateTime
  scheduledEndAt  DateTime? // 다일 데이트(여행 등) 종료일. null이면 당일.
  startTime       String?
  endTime         String?
  status          String    @default("planned")
  estimatedCost Int?
  summary       String?
  themeNote     String?
  weather       String?
  historyLabel  String?
  attachmentUrl String? // 외부 첨부 (여행 일정 HTML 등). 비우면 미노출.

  aiInput       String?
  aiResponseRaw String?

  createdById String
  createdBy   User   @relation("DateCreator", fields: [createdById], references: [id])

  stops    Stop[]
  reviews  Review[]
  tags     DateTag[]
  comments DateComment[]
  photos   DatePhoto[]
  buckets  Bucket[]      @relation("BucketDoneOn")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@schema("judy")
}

model Stop {
  id             Int     @id @default(autoincrement())
  dateId         String
  stepOrder      Int
  time           String
  emoji          String?
  name           String
  address        String?
  type           String?
  description    String?
  mapQuery       String
  naverMapUrl    String?
  cost           Int     @default(0)
  reservationUrl String?
  reserved       Boolean @default(false)
  // AI 모드에서 사용자가 고른 옵션 외 미선택 후보 2개. 당일 변경 참고용.
  // [{ emoji, name, address, type, description, mapQuery, estimatedCost }]
  alternatives   Json?

  date Date @relation(fields: [dateId], references: [id], onDelete: Cascade)

  @@index([dateId])
  @@schema("judy")
}

model Review {
  id        Int      @id @default(autoincrement())
  dateId    String
  userId    String
  stars     Int
  oneLine   String?
  createdAt DateTime @default(now())

  date Date @relation(fields: [dateId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@unique([dateId, userId])
  @@schema("judy")
}

model DateTag {
  dateId String
  tag    String

  date Date @relation(fields: [dateId], references: [id], onDelete: Cascade)

  @@id([dateId, tag])
  @@schema("judy")
}

model Anniversary {
  id          Int      @id @default(autoincrement())
  label       String
  date        DateTime
  emoji       String?
  recurring   Boolean  @default(true)
  createdById String
  createdBy   User     @relation("AnniversaryCreator", fields: [createdById], references: [id])

  userId  String?
  subject User?   @relation("AnniversarySubject", fields: [userId], references: [id], onDelete: Cascade)
  kind    String?

  createdAt DateTime @default(now())

  @@unique([userId, kind])
  @@index([date])
  @@schema("judy")
}

model Bucket {
  id          Int       @id @default(autoincrement())
  title       String
  emoji       String?
  description String?
  area        String?
  priority    Int       @default(0)
  done        Boolean   @default(false)
  doneAt      DateTime?

  doneDateId String?
  doneDate   Date?   @relation("BucketDoneOn", fields: [doneDateId], references: [id], onDelete: SetNull)

  createdById String
  createdBy   User   @relation("BucketCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([done, priority])
  @@schema("judy")
}

model TimeCapsule {
  id       Int       @id @default(autoincrement())
  title    String
  body     String
  openAt   DateTime
  opened   Boolean   @default(false)
  openedAt DateTime?

  // soft-delete — 삭제해도 행은 남기고 deletedAt 표시. admin 이 복원 가능.
  deletedAt DateTime?

  createdById String
  createdBy   User   @relation("CapsuleCreator", fields: [createdById], references: [id])

  createdAt DateTime @default(now())

  @@index([openAt])
  @@schema("judy")
}

model DateComment {
  id        Int      @id @default(autoincrement())
  dateId    String
  date      Date     @relation(fields: [dateId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  body      String
  createdAt DateTime @default(now())

  @@index([dateId, createdAt])
  @@schema("judy")
}

model DatePhoto {
  id           Int      @id @default(autoincrement())
  dateId       String
  date         Date     @relation(fields: [dateId], references: [id], onDelete: Cascade)
  url          String
  key          String?
  caption      String?
  width        Int?
  height       Int?
  uploadedById String
  uploadedBy   User     @relation("PhotoUploader", fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([dateId, createdAt])
  @@schema("judy")
}

model PersonalEvent {
  id        Int       @id @default(autoincrement())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  startsAt  DateTime
  endsAt    DateTime?
  allDay    Boolean   @default(false)
  category  String?
  emoji     String?
  note      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([userId, startsAt])
  @@index([startsAt])
  @@schema("judy")
}

model PushSubscription {
  id         Int       @id @default(autoincrement())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint   String    @unique
  p256dh     String
  auth       String
  userAgent  String?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?

  @@index([userId])
  @@schema("judy")
}

// 1:1 채팅 메시지. 둘이서만 쓰는 앱이라 별도 chat room 모델 없이 글로벌 1개.
model ChatMessage {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  body      String   // 이미지만 보낼 때는 빈 문자열 가능
  imageUrl  String?
  imageKey  String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@schema("judy")
}

// 한 사용자가 마지막으로 읽은 메시지 ID. unread 카운트 계산에 사용.
model ChatRead {
  userId     String   @id
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lastReadId Int?
  updatedAt  DateTime @updatedAt

  @@schema("judy")
}

// 하루 한 줄 (데일리 챌린지). 양쪽 모두 작성한 연속 날짜 수가 스트릭.
model DailyEntry {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String   // 'YYYY-MM-DD' (KST 자정 기준)
  body      String
  emoji     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([date])
  @@schema("judy")
}

// 사주 운세 캐시 — 같은 (kind, periodKey) 에 대해 한 번만 생성하고 재사용.
//   - kind: "daily" | "weekly"
//   - periodKey: daily="YYYY-MM-DD" (KST), weekly="week-YYYY-MM-DD" (그 주 일요일)
//   - body: { fox: string, bunny: string, combined: string }
model SajuFortune {
  id        Int      @id @default(autoincrement())
  kind      String
  periodKey String
  body      Json
  createdAt DateTime @default(now())

  @@unique([kind, periodKey])
  @@schema("judy")
}

// 데일리 Q&A 의 그날 질문 (date 기준 양쪽 사용자가 같은 질문을 답하도록 고정).
// 한번 결정되면 다시 안 바뀜 — pool 이 바뀌어도 과거 답변 컨텍스트 보존.
model DailyQuestion {
  date      String   @id  // 'YYYY-MM-DD' (KST)
  question  String
  createdAt DateTime @default(now())

  @@schema("judy")
}

// 스케줄러 dedup 용 — 같은 (kind, key) 는 한 번만 발송.
//   - kind: 'dday-1' | 'anniversary-morning' | ...
//   - key:  'date-{id}' | 'anni-{id}-{YYYY-MM-DD}'
model NotificationLog {
  id     Int      @id @default(autoincrement())
  kind   String
  key    String
  sentAt DateTime @default(now())

  @@unique([kind, key])
  @@schema("judy")
}
